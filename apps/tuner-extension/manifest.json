{
  "manifest_version": 3,
  "name": "ProsodiaTunerExtension",
  "version": "1.0.0",
  "description": "Interactive acoustic emotion tuner and live analyzer for Project Prosodia.",
  "permissions": [
    "activeTab",
    "tabs",
    "tabCapture",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.vimeo.com/*", "*://*/*"],
      "js": ["content.js"]
    }
  ]
}
